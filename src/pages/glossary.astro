---
import BaseLayout from '../layouts/BaseLayout.astro';

const terms = [
  {
    word: 'プログラム',
    yomi: 'program',
    desc: '読み手（コンピュータ）に宛てて書く、曖昧さのない文。上から順に読まれ、書いたとおりのことが起きる。',
  },
  {
    word: 'エラー',
    yomi: 'error',
    desc: '誠実な読み手からの返事。「ここまで読めた。ここで分からなくなった」という、世界でいちばん正確な読書感想文。失敗の印ではない。',
  },
  {
    word: '変数',
    yomi: 'variable',
    desc: '値につけた名前（あだ名）。箱ではない。同じ値に複数の名前をつけられるし、名前は別の値に付け替えられる。',
  },
  {
    word: 'ループ（くりかえし）',
    yomi: 'loop',
    desc: '「3回ノックして」という日本語の省略を、コンピュータに通じる形にしたもの。新しい概念ではなく、ことばに最初からある仕組みの形式化。',
  },
  {
    word: '条件分岐（もしも）',
    yomi: 'if',
    desc: '「もし雨なら傘を持つ」の形式化。条件は「ほんとうか、うそか」で答えられる文でなければならない。',
  },
  {
    word: '関数',
    yomi: 'function',
    desc: '辞書に新しいことばを載せること。一度「ゆでる」を定義すれば、毎回ゆで方を説明せずに済む。定義は一度、使用は何度でも。',
  },
  {
    word: '引数',
    yomi: 'argument',
    desc: 'ことばが要求する「〜を」「〜で」の空欄。「ゆでる（卵を、7分）」の卵と7分。',
  },
  {
    word: '式',
    yomi: 'expression',
    desc: '評価されると値になるもの。「1 + 2 × 3」は式で、評価すると 7 という値になる。文が「こと」なら、式は「もの」。',
  },
  {
    word: '評価',
    yomi: 'evaluation',
    desc: '式を値にすること。実体は「構造の木を、深い葉っぱから順に畳む」操作。',
  },
  {
    word: '構文木',
    yomi: 'syntax tree',
    desc: '文の構造を枝分かれで描いたもの。プログラムの中では { op, left, right } のような、ただのデータの入れ子。',
  },
  {
    word: 'トークン',
    yomi: 'token',
    desc: 'ことばの粒。「言語の庭」を「言語/の/庭」と区切るように、コンピュータも文をまず粒に分けてから読む。',
  },
  {
    word: '字句解析',
    yomi: 'lexical analysis',
    desc: '文字の列をトークン（粒）に切り分ける工程。言語処理系の3工程の1番目。',
  },
  {
    word: '構文解析',
    yomi: 'parsing',
    desc: 'トークンの並びから構造の木を組み立てる工程。3工程の2番目。優先順位の正体は、この工程が作る木のかたち。',
  },
  {
    word: 'インタプリタ',
    yomi: 'interpreter',
    desc: '文字列→粒→木→値、と進む翻訳の手順を書いたプログラム。その場で意味にする。書き出しておくならコンパイラ。',
  },
  {
    word: '再帰',
    yomi: 'recursion',
    desc: '手順の中に自分自身が現れること。木の枝の先にまた木があるから、木を畳む手順には再帰が自然に現れる。目が回るのは普通。',
  },
  {
    word: 'バグ',
    yomi: 'bug',
    desc: '意図と動作のずれ。文法のまちがいはコンピュータが教えてくれるが、意図とのずれはあなたにしか分からない。',
  },
  {
    word: '環境',
    yomi: 'environment',
    desc: '言語の記憶の正体。名前→値の対応表（辞書）が1冊あるだけ。変数が「箱」でない証拠でもある。',
  },
  {
    word: 'スコープ',
    yomi: 'scope',
    desc: '名前が通じる範囲。実装の正体は辞書の重なり——関数を呼ぶたびにローカルな辞書を1冊重ね、手前から引く。',
  },
  {
    word: '真偽値',
    yomi: 'boolean',
    desc: '「はい」「いいえ」という値。何を真とするか（1は真か？）の答えは言語ごとにちがう。真理の境界線すら設計。',
  },
  {
    word: 'キーワード',
    yomi: 'keyword',
    desc: 'if や while のような言語の合図。意味と表記は別もので、表記は対応表1枚で差し替えられる衣装にすぎない。',
  },
  {
    word: '停止性問題',
    yomi: 'halting problem',
    desc: '「このプログラムは止まるか」を実行せずに判定するプログラムは書けない——書けないことが証明されている（チューリング、1936）。',
  },
  {
    word: '正規表現',
    yomi: 'regular expression',
    desc: 'ことばの「かたち」を言い当てる、数文字で書ける小さな言語。検索窓の裏に住んでいる。数えることはできないが、そのかわり暴走しない。',
  },
  {
    word: 'もよう（パターン）',
    yomi: 'pattern',
    desc: '正規表現で書いた検索の指示書。特定のことばではなく「電話番号っぽさ」「日付っぽさ」のような、ことばのかたちを指す。',
  },
  {
    word: '状態機械',
    yomi: 'state machine',
    desc: '丸（状態）と矢印（遷移）でできた機械。正規表現は実行のたびにこれに組み立てられる。覚え書きが有限個しかないので、入れ子は数えられない。',
  },
  {
    word: 'アルゴリズム',
    yomi: 'algorithm',
    desc: '曖昧さがなく、必ず終わる手順。プログラムはそれをことばにしたもの。9世紀の数学者アル＝フワーリズミーの名前がなまった。',
  },
  {
    word: '二分探索',
    yomi: 'binary search',
    desc: 'そろっている列のまんなかを見て、半分を捨てる——のくりかえし。100万個でも約20回。速さは「そろっている」という前提への信頼で買っている。',
  },
  {
    word: '計算量',
    yomi: 'computational complexity',
    desc: '手順の手間を「くらべた回数」で測ったときの、増え方のかたち。対数・比例・n log n・2乗。機械を速くするより、かたちを変える方が効く。',
  },
  {
    word: 'メモ化',
    yomi: 'memoization',
    desc: '一度計算した答えに名前をつけてとっておき、二度目は計算せずに答える工夫。速さを記憶の場所代で買う——時間と空間のトレードオフ。',
  },
  {
    word: 'チューリング機械',
    yomi: 'Turing machine',
    desc: 'テープ・ヘッド・状態だけでできた、思考のための最小の計算機械。コンピュータが生まれる前に、計算の限界をこの機械が教えてくれた。',
  },
  {
    word: '万能機械',
    yomi: 'universal machine',
    desc: 'テープに書かれた他の機械の表を読んで、そのまねをする機械。「プログラムもデータである」の原点。あなたがコース2で作った評価器も、その一員。',
  },
  {
    word: '対角線論法',
    yomi: 'diagonal argument',
    desc: '名簿の対角線をたどってぜんぶ裏返すと、名簿のどの行とも食い違うものが作れる——という技。停止性問題の証明の心臓部（カントール、1891）。',
  },
  {
    word: '型',
    yomi: 'type',
    desc: '値の種類（数・真偽など）と、その種類にゆるされた操作の決まり。「一冊」「一頭」の助数詞がまちがうと感じる、あの違和感の親戚。',
  },
  {
    word: '型検査',
    yomi: 'type checking',
    desc: 'プログラムを実行せずに読んで、型のつじつまを調べること。実行が一本の道しか調べないのに対し、読む検査はすべての道をいっぺんに調べる。',
  },
  {
    word: '型推論',
    yomi: 'type inference',
    desc: '書かなくても分かる型を、機械が埋めてくれること。「x * 2 が数なら、戻りも数」のように、式のかたちから型をたどる。',
  },
  {
    word: 'チョムスキー階層',
    yomi: 'Chomsky hierarchy',
    desc: '言語を力の順にならべた地図。正規言語＜文脈自由言語＜チューリング機械。力が増すごとに、速さや「止まる保証」をレジに置いていく。',
  },
];
---

<BaseLayout title="用語の庭" description="この庭のことばで書いた、小さな用語集。">
  <main class="container">
    <header class="gl-header">
      <p class="leaf-rule">用語の庭</p>
      <h1>ことばの、植物図鑑。</h1>
      <p class="gl-lead">教科書の定義ではなく、この庭の声で書いてあります。</p>
    </header>
    <dl class="gl-list">
      {
        terms.map((t) => (
          <div class="gl-item">
            <dt>
              {t.word} <span class="gl-yomi">{t.yomi}</span>
            </dt>
            <dd>{t.desc}</dd>
          </div>
        ))
      }
    </dl>
  </main>
</BaseLayout>

<style>
  .gl-header {
    padding-block: var(--space-6) var(--space-4);
    max-width: var(--measure);
  }

  .gl-lead {
    color: var(--c-ink-2);
    margin-top: var(--space-2);
  }

  .gl-list {
    max-width: var(--measure);
    margin: 0 0 var(--space-7);
    display: grid;
    gap: var(--space-3);
  }

  .gl-item {
    border: 1px solid var(--c-line);
    border-radius: var(--radius-md);
    padding: var(--space-3) var(--space-4);
    background: var(--c-paper);
  }

  .gl-item dt {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.05rem;
    margin-bottom: var(--space-1);
  }

  .gl-yomi {
    font-family: var(--font-code);
    font-size: 0.75rem;
    color: var(--c-ink-3);
    font-weight: 400;
    margin-left: 0.5em;
  }

  .gl-item dd {
    margin: 0;
    color: var(--c-ink-2);
    font-size: 0.95rem;
    line-height: 1.95;
  }
</style>
